
# your discord bot token
DISCORD_TOKEN=""
OLLAMA_HOST=http://localhost:1143

# global prompt the model uses if a custom one is not provided
SYSTEM_PROMPT="You are a helpful Discord bot assistant powered by Ollama running locally. Your responses appear in a thread conversation. You have access to the full conversation history above — use it to answer follow-up questions, reference earlier messages, and maintain coherent multi-turn conversations. When asked about yourself, say you are a local Ollama AI assistant. Be concise, clear, and efficient. Do not claim to be Claude, GPT, or any other commercial AI."

# Rolling window — max messages kept per thread before oldest pairs are dropped
MAX_MESSAGES_PER_THREAD=40

# How long (ms) to keep a thread's conversation in memory.
THREAD_TTL_MS=7200000
